FROM ubuntu:22.04

RUN apt-get update && apt-get install -y \
    squid-openssl \
    openssl \
    && rm -rf /var/lib/apt/lists/*

# Create directories
RUN mkdir -p /etc/squid/ssl /var/spool/squid /var/log/squid /var/lib/squid/ssl_db \
    && chown -R proxy:proxy /var/spool/squid /var/log/squid /var/lib/squid

# Copy config and entrypoint
COPY squid.conf /etc/squid/squid.conf
COPY entrypoint.sh /entrypoint.sh
RUN chmod +x /entrypoint.sh

EXPOSE 3128

ENTRYPOINT ["/entrypoint.sh"]
